{
  "name": "lamcs-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cf:build": "npx @cloudflare/next-on-pages",
    "cf:dev": "wrangler pages dev .vercel/output --d1 DB=./prisma/dev.db",
    "cf:deploy": "wrangler pages deploy .vercel/output",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:d1:sql": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script --output=prisma/d1-schema.sql",
    "db:d1:init:local": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script --output=prisma/d1-schema.sql && wrangler d1 execute lamcs-db --local --file=./prisma/d1-schema.sql",
    "db:d1:init:remote": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script --output=prisma/d1-schema.sql && wrangler d1 execute lamcs-db --remote --file=./prisma/d1-schema.sql",
    "db:d1:seed": "wrangler d1 execute lamcs-db --local --file=./prisma/seed.sql",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-d1": "^6.19.0",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^2.4.3",
    "next": "14.2.35",
    "next-auth": "^4.24.14",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.0",
    "@cloudflare/workers-types": "^4.20240923.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^6.19.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.0.0",
    "typescript": "^5",
    "wrangler": "^3.78.0"
  }
}
